{
  "name": "eslint-plugin-parallelize",
  "version": "0.1.1",
  "description": "ESLint rule that flags sequential awaits with no data dependency between them, and auto-fixes them into maximally parallel Promise.all groupings. Type-aware when type information is available.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "typescript",
    "async",
    "await",
    "promise",
    "parallel",
    "performance"
  ],
  "license": "MIT",
  "author": "Braeden Smith <braedensmith2@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braeden/eslint-plugin-parallelize.git"
  },
  "bugs": "https://github.com/braeden/eslint-plugin-parallelize/issues",
  "homepage": "https://github.com/braeden/eslint-plugin-parallelize#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsx --test test/*.test.ts",
    "lint:demo": "eslint examples/",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0"
  },
  "peerDependencies": {
    "eslint": ">=8.57.0",
    "typescript": ">=4.8.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  }
}
